# Copy this file to .env and fill in your values
# LLM_MODEL=gemini (default): chat + text-only helpers use Gemini. Audio/image still need GEMINI_API_KEY.
# LLM_MODEL=groq: chat + text-only helpers use Groq (GROQ_API_KEY + GROQ_MODEL). Audio/image still use Gemini.
LLM_MODEL=gemini
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override default gemini-3.1-flash-lite-preview
# GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_TRANSLATION_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_TRANSCRIPTION_MODEL=gemini-3.1-flash-lite-preview

SARVAM_API_KEY=your_sarvam_api_key_here

# Image generation API (Freepik Seedream)
# FREEPIC_API_KEY=
# FREEPIC_API_URL=https://api.freepik.com/v1/ai/text-to-image/seedream-v4-5-edit

# Instagram Graph API (official) — requires a Facebook Page linked to an IG Business/Creator account.
# Get these from https://developers.facebook.com → Your App → Instagram Graph API.
IG_GRAPH_ACCESS_TOKEN=your_long_lived_page_access_token
IG_GRAPH_USER_ID=your_ig_business_account_id
IG_GRAPH_PAGE_ID=your_facebook_page_id
# IG_GRAPH_API_VERSION=v25.0

# Public HTTPS URL of this backend (required for sending images/audio in DMs).
# Use ngrok, Cloudflare Tunnel, or your production domain.
# Example: IG_DM_PUBLIC_BASE_URL=https://abc123.ngrok-free.app
IG_DM_PUBLIC_BASE_URL=

# Poll interval in seconds for checking new DMs (default 8)
# IG_DM_POLL_INTERVAL=8
